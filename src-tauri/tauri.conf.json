{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "dj-kat",
  "version": "0.1.0",
  "identifier": "dj-kat",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "dj-kat",
        "width": 400,
        "height": 352,
        "transparent": true,
        "decorations": false,
        "shadow": false,
        "resizable": false,
        "dragDropEnabled": false,
        "minWidth": 400,
        "maxWidth": 400
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
